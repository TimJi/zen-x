{
  "manifest_version": 3,
  "name": "ZenX",
  "version": "1.0.0",
  "description": "One-click zen reading mode for X.com articles",
  "homepage_url": "https://github.com/TimJi/zen-x",
  "permissions": ["activeTab", "scripting", "declarativeContent"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ZenX - 開啟 Zen 閱讀模式"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
